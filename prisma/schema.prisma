// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  adminEmail    String
  adminPassword String
  itPassword    String?
  themeColor    String   @default("#000000")
  logo          String?  @db.LongText
  location      String?
  phone         String?
  googleReviewUrl String?
  socialLinks   String?  @db.LongText
  payments      String? // JSON string or comma-separated: ["creditCard", "paypal", "localPay"]
  paymentConfig String? // JSON string for API keys/settings
  slotInterval  Int      @default(30) // in minutes between time slots
  minLeadTime   Int      @default(60) // minimum minutes in advance to book
  luckyWheelEnabled Boolean @default(false)
  luckyWheelLastDisabled DateTime?
  luckyWheelConfig String?  @db.LongText // JSON string for 5 prizes and percentages
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  services        Service[]
  staff           Staff[]
  bookings        Booking[]
  customers       Customer[]
  promotionClaims PromotionClaim[]
  coupons         Coupon[]
}

model Service {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  price     Float
  duration  Int // in minutes
  category  String?
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Staff {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  role      String   @default("Staff")
  phone     String?
  workHours String?  @db.Text
  dayOff    String?  @default("None")
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id            String   @id @default(uuid())
  tenantId      String
  customerName  String
  customerPhone String?
  serviceId     String
  staffId       String?
  customerId    String?
  date          String // YYYY-MM-DD
  time          String // HH:MM
  notes         String?  @db.Text
  status        String   @default("Pending") // Pending, Confirmed, Cancelled
  createdAt     DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service  Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff    Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  vip       Boolean  @default(false)
  points    Int      @default(0)
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model SystemSettings {
  id              String   @id @default("global")
  twilioSid       String?
  twilioAuthToken String?
  twilioPhone     String?
  pendingSmsTemplate  String? @db.Text
  approvedSmsTemplate String? @db.Text
  rejectedSmsTemplate String? @db.Text
  updatedAt       DateTime @updatedAt
}



model PromotionClaim {
  id          String   @id @default(uuid())
  tenantId    String
  phone       String
  prize       String
  status      String   @default("Unused") // Unused, Redeemed
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, phone]) // Ensure one spin per phone number per salon
}

model Coupon {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  code          String
  discountValue Float    // Percentage (e.g. 10 for 10%)
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
}

